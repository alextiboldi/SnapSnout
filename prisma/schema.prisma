generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Species {
  dog
  cat
  horse
  other
}

enum Lifestage {
  puppy
  kitten
  adult
  senior
  memorial
}

enum FamilyRole {
  owner
  member
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  locale    String   @default("en")
  isPremium Boolean  @default(true) @map("is_premium")
  familyId  String?  @map("family_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family          Family?          @relation("UserCurrentFamily", fields: [familyId], references: [id], onDelete: SetNull)
  ownedFamilies   Family[]         @relation("FamilyOwner")
  memberships     FamilyMember[]
  uploadedPhotos  Photo[]          @relation("PhotoUploader")
  sentInvites     FamilyInvite[]   @relation("InviteSender")
  milestoneShares MilestoneShare[] @relation("MilestoneShareCreator")

  @@map("users")
}

model Family {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String   @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User           @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members FamilyMember[]
  invites FamilyInvite[]
  pets    Pet[]
  users   User[]         @relation("UserCurrentFamily")

  @@map("families")
}

model FamilyMember {
  id          String     @id @default(uuid()) @db.Uuid
  familyId    String     @map("family_id") @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  role        FamilyRole @default(member)
  activePetId String?    @map("active_pet_id") @db.Uuid
  joinedAt    DateTime   @default(now()) @map("joined_at")

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  activePet Pet?   @relation("FamilyMemberActivePet", fields: [activePetId], references: [id], onDelete: SetNull)

  @@unique([familyId, userId])
  @@map("family_members")
}

model FamilyInvite {
  id              String    @id @default(uuid()) @db.Uuid
  familyId        String    @map("family_id") @db.Uuid
  email           String?
  token           String    @unique
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  revokedAt       DateTime? @map("revoked_at")

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("family_invites")
}

model Pet {
  id           String    @id @default(uuid()) @db.Uuid
  familyId     String    @map("family_id") @db.Uuid
  name         String
  species      Species
  breed        String?
  lifestage    Lifestage @default(puppy)
  dateOfBirth  DateTime? @map("date_of_birth")
  gotchaDay    DateTime  @map("gotcha_day")
  photoUrl     String?   @map("photo_url")
  isDeceased   Boolean   @default(false) @map("is_deceased")
  deceasedDate DateTime? @map("deceased_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  family         Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  milestones     Milestone[]
  photos         Photo[]
  activeForUsers FamilyMember[] @relation("FamilyMemberActivePet")

  @@index([familyId])
  @@map("pets")
}

model Milestone {
  id            String    @id @default(uuid()) @db.Uuid
  petId         String    @map("pet_id") @db.Uuid
  title         String
  description   String    @default("")
  emoji         String    @default("🎯")
  targetDate    DateTime? @map("target_date")
  completedDate DateTime? @map("completed_date")
  photoUrl      String?   @map("photo_url")
  notes         String?
  isCustom      Boolean   @default(false) @map("is_custom")
  tags          String[]  @default([])
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  pet    Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
  photos Photo[]
  share  MilestoneShare?

  @@map("milestones")
}

model MilestoneShare {
  id          String    @id @default(uuid()) @db.Uuid
  milestoneId String    @unique @map("milestone_id") @db.Uuid
  token       String    @unique
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  createdBy User      @relation("MilestoneShareCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("milestone_shares")
}

model Photo {
  id             String   @id @default(uuid()) @db.Uuid
  petId          String   @map("pet_id") @db.Uuid
  milestoneId    String?  @map("milestone_id") @db.Uuid
  uploaderId     String?  @map("uploader_id") @db.Uuid
  url            String
  capturedDate   DateTime @default(now()) @map("captured_date")
  caption        String?
  isMonthlyPhoto Boolean  @default(false) @map("is_monthly_photo")
  monthNumber    Int?     @map("month_number")
  createdAt      DateTime @default(now()) @map("created_at")

  pet       Pet        @relation(fields: [petId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  uploader  User?      @relation("PhotoUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@map("photos")
}
